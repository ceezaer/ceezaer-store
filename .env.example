# ============================================================
# CEEZAER STORE — Netlify Environment Variables
# Set ALL of these in: Netlify Dashboard → Site Settings → Environment Variables
# NEVER commit actual values to git.
# ============================================================

# --- Stripe ---
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...   # From Stripe → Webhooks → signing secret

# --- Stripe Price IDs ---
# Create products in Stripe dashboard, then paste price_xxx IDs here.
# Digital Products (one-time payments)
STRIPE_PRICE_TEMPLATE_PACK=price_...
STRIPE_PRICE_SOW_TEMPLATE=price_...
STRIPE_PRICE_PRICING_CALC=price_...
STRIPE_PRICE_TX_GUIDE=price_...
STRIPE_PRICE_CLIENT_AGREEMENT=price_...
STRIPE_PRICE_FLIGHT_CHECKLIST=price_...

# Platform Subscriptions (recurring monthly)
STRIPE_PRICE_PLATFORM_STARTER=price_...   # $99/mo
STRIPE_PRICE_PLATFORM_GROWTH=price_...    # $249/mo

# Service Deposits (one-time, to hold booking date)
STRIPE_PRICE_DEPOSIT_REALESTATE=price_...    # e.g. $100 deposit for $349 package
STRIPE_PRICE_DEPOSIT_ROOF=price_...          # e.g. $75 deposit for $149 package
STRIPE_PRICE_DEPOSIT_CONSTRUCTION=price_...  # e.g. $100 deposit for $249/mo package

# --- Digital Product Downloads ---
# Upload your product files to a storage bucket (AWS S3, Cloudflare R2, Google Cloud Storage)
# and set the base URL here. Files should be named:
#   template-pack.zip, sow-template.pdf, pricing-calc.xlsx, tx-guide.pdf,
#   client-agreement.pdf, flight-checklist.pdf
DOWNLOAD_BASE_URL=https://storage.googleapis.com/ceezaer-products

# --- Automation Server ---
# Your ceezaer-automation server (Render.com) — for sending download emails
AUTOMATION_SERVER_URL=https://ceezaer-automation-3.onrender.com
AUTOMATION_API_KEY=your-api-key-here

# --- Auto-set by Netlify (do not add manually) ---
# URL=https://ceezaer.com
